public class HcfExample {
    public static int findHCF(int a, int b) {
     
        a = Math.abs(a);
        b = Math.abs(b);
        
        while (b != 0) {
            int temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }

    public static void main(String[] args) {
        int num1 = 60;
        int num2 = 72;
        System.out.println("HCF of " + num1 + " and " + num2 + " is: " + findHCF(num1, num2));
  
    }
}


