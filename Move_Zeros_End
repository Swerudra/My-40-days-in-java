import java.util.*;
public class Zeros_End_Array {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		int n= sc.nextInt();
		
		int arr[] = new int[n];
		for(int i=0;i<n;i++) {
			arr[i] = sc.nextInt();
		}
		int j=0;
		for(int i=0;i<n;i++) {
			if(arr[i] !=0) {
				arr[j++] = arr[i];
			}
		}
		
		while(j<n) {
			arr[j++] = 0;
		}
		
		for(int i=0;i<n;i++) {
			System.out.println(arr[i]);
		}
	}

}

/* 
Input: 2 3 0 5 0 6
Output: 2 3 5 6 0 0
*/
