public class StringCompression {

	public static void main(String[] args) {
		String s = "aabbbcc";
		String r =" ";
		int c=1;
		for(int i=0;i<s.length();i++) {
			
			if(i<s.length()-1 && s.charAt(i) == s.charAt(i+1)) {
				c ++;
				
			}
			else {
				r += s.charAt(i) + String.valueOf(c) ;
				c=1;
			}
		}
		System.out.println(r);
	}

}
