package basicjava;

public class Larg_array {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int[] a = {34,53,42,23,10};
		int lar = a[0];
		int small = a[0];
		for(int i=0;i<a.length;i++) {
			if(lar< a[i]) {
				lar = a[i];
			}
			if(small> a[i]) {
				small = a[i];
			}
		}
		System.out.println("Largest: " + lar);
		System.out.println("Smallest: " + small);
	}

}
