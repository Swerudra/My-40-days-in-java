
public class Transpose_Matrix {

	public static void main(String[] args) {
		
		int [][] t = {{2,4},{6,7}};
		for(int i=0;i<t.length;i++){
			
			for(int j=0;j<t.length;j++) {
				System.out.print(t[j][i] + " ");
			}
			System.out.println();
		}
		
		//Rotate loop by 90degree
		
		for(int i=0;i<t.length;i++) {
		    for(int j=t.length-1;j>=0;j--) {
		        System.out.print(t[j][i] + " ");
		    }
		    System.out.println();
		}
		
		
	}

}
