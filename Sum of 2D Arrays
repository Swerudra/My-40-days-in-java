package _40days;

public class Sum_2dArr {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int a[][] = {{1,2,3},{3,4,6},{1,2,3}};
		int sum =0 ;
		for(int i=0;i<a.length;i++) {
			for(int j=0;j<a.length;j++) {
				sum = sum + a[i][j];
			}
		}
		System.out.println("Sum of 2d Array: "+ sum);

	}

}
